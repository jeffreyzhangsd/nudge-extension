{
  "manifest_version": 3,
  "name": "Nudge",
  "version": "1.0.0",
  "description": "Lightweight recurring reminder app. Pings you at set intervals so you never forget to drink water, stretch, or take a break.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Nudge",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["alarms", "storage", "notifications", "offscreen"],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
